# ────────────────────────────────────────────────────────────────────
# HomeDirectAI — Environment Variables
# Copy this file to .env and fill in your values.
# The AI engine tries providers in order: Together AI → Fireworks AI → DeepSeek → rule-based fallback
# ────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────

# PostgreSQL connection URL (REQUIRED for production)
# Railway: Add PostgreSQL plugin → copy DATABASE_URL from Variables tab
# Local: postgresql://user:password@localhost:5432/homedirect
DATABASE_URL=

# ── AI Providers (uses the first available API key, in order) ────────

# Primary: Together AI (recommended — supports fine-tuned Llama models)
# Get your key at: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=
# Optional: Override the default model (meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo)
# Use this to point to your fine-tuned model once trained
TOGETHER_MODEL=

# Model size: "small" (8B), "medium" (70B), "large" (405B)
# Larger = better reasoning but higher cost and latency
AI_MODEL_SIZE=small

# Fallback 1: Fireworks AI
# Get your key at: https://fireworks.ai/account/api-keys
FIREWORKS_API_KEY=
FIREWORKS_MODEL=

# Fallback 2: DeepSeek (legacy — kept for backward compatibility)
# Get your key at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# ── Real Estate Data ─────────────────────────────────────────────────

# RapidAPI key for Realtor16 MLS listings
# Sign up at: https://rapidapi.com/apidojo/api/realtor
RAPIDAPI_KEY=

# ── Payments ─────────────────────────────────────────────────────────

# Stripe secret key for processing payments (walkthroughs, closing fees)
# Get your key at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=

# ── Email (SendGrid via SMTP or any SMTP provider) ──────────────────

# SendGrid: Use smtp.sendgrid.net, port 587, user "apikey", pass = your API key
# Or any SMTP provider (Gmail, Mailgun, etc.)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=
SMTP_FROM=noreply@homedirectai.com

# ── File Storage (Cloudflare R2 / S3-compatible) ─────────────────────

# Cloudflare R2 for property photos and document uploads
# Get credentials at: https://dash.cloudflare.com → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=homedirect-uploads
# Public URL for serving files (set up a custom domain or use R2 public URL)
R2_PUBLIC_URL=

# ── DocuSign E-Signature ─────────────────────────────────────────────

# DocuSign integration for electronic document signing
# Sign up at: https://developers.docusign.com
# Use demo environment for testing, production for live transactions
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_SECRET_KEY=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_USER_ID=
# RSA private key for JWT auth (replace \n with actual newlines or use \\n)
DOCUSIGN_PRIVATE_KEY=
# Demo: https://demo.docusign.net/restapi  Prod: https://na4.docusign.net/restapi
DOCUSIGN_BASE_URL=https://demo.docusign.net/restapi
# Demo: https://account-d.docusign.com  Prod: https://account.docusign.com
DOCUSIGN_OAUTH_BASE=https://account-d.docusign.com
DOCUSIGN_REDIRECT_URI=http://localhost:5000/api/docusign/callback

# ── Session & Security ────────────────────────────────────────────────

# Secret key for encrypting user sessions (use a long random string)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=

# Encryption key for PII data at rest (SSN, bank accounts, addresses, questionnaire data)
# CRITICAL: Set this in production. 64-character hex string.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If not set, falls back to SESSION_SECRET (less secure but functional)
ENCRYPTION_KEY=

# ── Application ───────────────────────────────────────────────────────

NODE_ENV=development
PORT=5000
